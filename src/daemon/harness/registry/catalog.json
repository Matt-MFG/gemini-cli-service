    "paperless-ngx": {
      "name": "paperless-ngx",
      "displayName": "Paperless-ngx",
      "description": "Document management with OCR",
      "category": "documents",
      "image": "ghcr.io/paperless-ngx/paperless-ngx:latest",
      "harness": {
        "requires": ["postgres", "redis"],
        "postgres": { "database": "paperless" },
        "redis": { "db": 5 }
      },
      "env": {
        "PAPERLESS_DBHOST": "harness-postgres",
        "PAPERLESS_DBPORT": "5432",
        "PAPERLESS_DBNAME": "paperless",
        "PAPERLESS_DBUSER": "harness",
        "PAPERLESS_DBPASS": "{{harness.postgres.password}}",
        "PAPERLESS_REDIS": "{{harness.redis.url}}/5",
        "PAPERLESS_URL": "http://paperless.{{domain}}",
        "PAPERLESS_SECRET_KEY": "{{generate:hex:32}}",
        "PAPERLESS_ADMIN_USER": "admin",
        "PAPERLESS_ADMIN_PASSWORD": "{{generate:hex:16}}"
      },
      "ports": { "internal": 8000 },
      "volumes": { "data": "/usr/src/paperless/data", "media": "/usr/src/paperless/media", "consume": "/usr/src/paperless/consume" },
      "healthCheck": { "path": "/api/", "interval": 30 },
      "cli": {
        "tools": ["psql", "curl", "jq"],
        "envDoc": {
          "PAPERLESS_TOKEN": "API token for Paperless-ngx (create via /api/token/)",
          "PAPERLESS_API_URL": "Base URL for Paperless-ngx"
        },
        "aliases": {
          "paperless-docs": "curl -s -H \"Authorization: Token $PAPERLESS_TOKEN\" \"$PAPERLESS_API_URL/api/documents/?ordering=-created\" | jq '.results[] | {id: .id, title: .title, correspondent: .correspondent}'",
          "paperless-tags": "curl -s -H \"Authorization: Token $PAPERLESS_TOKEN\" \"$PAPERLESS_API_URL/api/tags/\" | jq '.results[] | {id: .id, name: .name}'"
        },
        "examples": [
          "paperless-docs",
          "psql -d paperless -c \"SELECT title, created, correspondent_id FROM documents_document ORDER BY created DESC LIMIT 10;\""
        ],
        "database": "paperless"
      }
    },

