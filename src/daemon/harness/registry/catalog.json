      "image": "baserow/baserow:latest",
      "harness": {
        "requires": ["postgres", "redis"],
        "postgres": { "database": "baserow" },
        "redis": { "db": 3 }
      },
      "env": {
        "DATABASE_HOST": "harness-postgres",
        "DATABASE_PORT": "5432",
        "DATABASE_NAME": "baserow",
        "DATABASE_USER": "harness",
        "DATABASE_PASSWORD": "{{harness.postgres.password}}",
        "REDIS_URL": "{{harness.redis.url}}/3",
        "BASEROW_PUBLIC_URL": "http://baserow.{{domain}}",
        "SECRET_KEY": "{{generate:hex:32}}"
      },
      "ports": { "internal": 80 },
      "volumes": { "data": "/baserow/data" },
      "healthCheck": { "path": "/api/_health/", "interval": 30 },
      "cli": {
        "tools": ["psql", "curl", "jq"],
        "envDoc": {
          "BASEROW_TOKEN": "Database token for Baserow API",
          "BASEROW_URL": "Base URL for Baserow"
        },
        "aliases": {
          "baserow-tables": "curl -s -H \"Authorization: Token $BASEROW_TOKEN\" \"$BASEROW_URL/api/database/tables/database/$1/\" | jq '.[] | {id: .id, name: .name}'",
          "baserow-rows": "curl -s -H \"Authorization: Token $BASEROW_TOKEN\" \"$BASEROW_URL/api/database/rows/table/$1/?size=10\" | jq '.results'"
        },
        "examples": [
          "baserow-tables 1",
          "psql -d baserow -c \"SELECT name FROM database_table ORDER BY created_on DESC LIMIT 10;\""
        ],
        "database": "baserow"
      }
    },

    "filebrowser": {
      "name": "filebrowser",
      "displayName": "File Browser",
      "description": "Web-based file manager",
      "category": "files",
      "image": "filebrowser/filebrowser:latest",
      "harness": {
        "requires": []
      },
      "env": {},
      "ports": { "internal": 80 },
      "volumes": { "data": "/srv", "config": "/database" },
      "healthCheck": { "path": "/health", "interval": 30 },
      "cli": {
        "tools": ["curl", "jq"],
        "envDoc": {
          "FILEBROWSER_URL": "Base URL for File Browser",
          "FILEBROWSER_TOKEN": "JWT token (POST /api/login with username/password)"
        },
        "aliases": {
          "fb-ls": "curl -s -H \"X-Auth: $FILEBROWSER_TOKEN\" \"$FILEBROWSER_URL/api/resources/$1\" | jq '.items[] | {name: .name, size: .size, type: .type}'"
        },
        "examples": [
          "fb-ls /",
          "curl -s -X POST \"$FILEBROWSER_URL/api/login\" -d '{\"username\":\"admin\",\"password\":\"admin\"}'"
        ]
      }
    },

    "formbricks": {
      "name": "formbricks",
      "displayName": "Formbricks",
      "description": "Open-source forms and survey platform",
      "category": "forms",
      "image": "ghcr.io/formbricks/formbricks:latest",
      "harness": {
        "requires": ["postgres"],
        "postgres": { "database": "formbricks" }
      },
      "env": {
        "DATABASE_URL": "postgres://harness:{{harness.postgres.password}}@harness-postgres:5432/formbricks",
        "NEXTAUTH_SECRET": "{{generate:hex:32}}",
        "NEXTAUTH_URL": "http://formbricks.{{domain}}",
        "ENCRYPTION_KEY": "{{generate:hex:32}}"
      },
      "ports": { "internal": 3000 },
      "healthCheck": { "path": "/api/health", "interval": 30 },
      "cli": {
        "tools": ["psql", "curl", "jq"],
        "envDoc": {
          "FORMBRICKS_API_KEY": "API key for Formbricks",
          "FORMBRICKS_URL": "Base URL for Formbricks"
        },
        "aliases": {
          "formbricks-surveys": "curl -s -H \"x-api-key: $FORMBRICKS_API_KEY\" \"$FORMBRICKS_URL/api/v1/management/surveys\" | jq '.data[] | {id: .id, name: .name, status: .status}'",
          "formbricks-responses": "curl -s -H \"x-api-key: $FORMBRICKS_API_KEY\" \"$FORMBRICKS_URL/api/v1/management/surveys/$1/responses\" | jq '.data | length'"
        },
        "examples": [
          "formbricks-surveys",
          "psql -d formbricks -c \"SELECT name, status, created_at FROM \\\"Survey\\\" ORDER BY created_at DESC LIMIT 10;\""
        ],
        "database": "formbricks"
      }
    },

    "grafana": {
      "name": "grafana",
      "displayName": "Grafana",
      "description": "Monitoring and observability dashboards",
      "category": "monitoring",
      "image": "grafana/grafana:latest",
      "harness": {
        "requires": []
      },
      "env": {
        "GF_SERVER_ROOT_URL": "http://grafana.{{domain}}",
        "GF_SECURITY_ADMIN_PASSWORD": "{{generate:hex:16}}"
      },
      "ports": { "internal": 3000 },
      "volumes": { "data": "/var/lib/grafana" },
      "healthCheck": { "path": "/api/health", "interval": 30 },
      "cli": {
        "tools": ["curl", "jq"],
        "envDoc": {
          "GRAFANA_URL": "Base URL for Grafana",
          "GRAFANA_API_KEY": "API key (create in Configuration > API Keys)"
        },
        "aliases": {
          "grafana-dashboards": "curl -s -H \"Authorization: Bearer $GRAFANA_API_KEY\" \"$GRAFANA_URL/api/search?type=dash-db\" | jq '.[] | {uid: .uid, title: .title}'",
          "grafana-datasources": "curl -s -H \"Authorization: Bearer $GRAFANA_API_KEY\" \"$GRAFANA_URL/api/datasources\" | jq '.[] | {id: .id, name: .name, type: .type}'"
        },
        "examples": [
          "grafana-dashboards",
          "curl -s -H \"Authorization: Bearer $GRAFANA_API_KEY\" \"$GRAFANA_URL/api/datasources\" | jq length"
        ]
      }
    },

    "activepieces": {
      "name": "activepieces",
      "displayName": "Activepieces",
      "description": "No-code workflow automation",
      "category": "automation",
      "image": "activepieces/activepieces:latest",
      "harness": {
        "requires": ["postgres", "redis"],
        "postgres": { "database": "activepieces" },
        "redis": { "db": 4 }
      },
      "env": {
        "AP_POSTGRES_DATABASE": "activepieces",
        "AP_POSTGRES_HOST": "harness-postgres",
        "AP_POSTGRES_PORT": "5432",
        "AP_POSTGRES_USERNAME": "harness",
        "AP_POSTGRES_PASSWORD": "{{harness.postgres.password}}",
        "AP_REDIS_URL": "{{harness.redis.url}}/4",
        "AP_FRONTEND_URL": "http://activepieces.{{domain}}",
        "AP_ENCRYPTION_KEY": "{{generate:hex:16}}",
        "AP_JWT_SECRET": "{{generate:hex:32}}"
      },
      "ports": { "internal": 8080 },
      "healthCheck": { "path": "/api/v1/flags", "interval": 30 },
      "cli": {
        "tools": ["psql", "curl", "jq"],
        "envDoc": {
          "AP_API_KEY": "API key for Activepieces",
          "AP_URL": "Base URL for Activepieces"
        },
        "aliases": {
          "ap-flows": "curl -s -H \"Authorization: Bearer $AP_API_KEY\" \"$AP_URL/api/v1/flows\" | jq '.data[] | {id: .id, name: .version.displayName, status: .status}'",
          "ap-runs": "curl -s -H \"Authorization: Bearer $AP_API_KEY\" \"$AP_URL/api/v1/flow-runs?limit=10\" | jq '.data[] | {id: .id, status: .status, flowDisplayName: .flowDisplayName}'"
        },
        "examples": [
          "ap-flows",
          "psql -d activepieces -c \"SELECT display_name, status FROM flow ORDER BY updated DESC LIMIT 10;\""
        ],
        "database": "activepieces"
      }
    },

    "stirling-pdf": {
      "name": "stirling-pdf",
      "displayName": "Stirling PDF",
      "description": "PDF manipulation tools",
      "category": "tools",
      "image": "frooodle/s-pdf:latest",
      "harness": {
        "requires": []
      },
      "env": {
        "DOCKER_ENABLE_SECURITY": "false"
      },
      "ports": { "internal": 8080 },
      "volumes": { "data": "/usr/share/tessdata" },
      "healthCheck": { "path": "/api/v1/general/health", "interval": 30 },
      "cli": {
        "tools": ["curl"],
        "envDoc": {
          "STIRLING_URL": "Base URL for Stirling PDF"
        },
        "aliases": {
          "pdf-merge": "curl -s -X POST \"$STIRLING_URL/api/v1/general/merge-pdfs\" -F 'fileInput=@$1' -F 'fileInput=@$2' -o merged.pdf"
        },
        "examples": [
          "curl -s -X POST \"$STIRLING_URL/api/v1/general/merge-pdfs\" -F 'fileInput=@file1.pdf' -F 'fileInput=@file2.pdf' -o merged.pdf"
        ]
      }
    },

