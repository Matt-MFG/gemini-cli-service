          "NOCODB_API_TOKEN": "API token for NocoDB",
          "NOCODB_URL": "Base URL for NocoDB"
        },
        "aliases": {
          "nocodb-bases": "curl -s -H \"xc-token: $NOCODB_API_TOKEN\" \"$NOCODB_URL/api/v1/db/meta/projects/\" | jq '.list[] | {id: .id, title: .title}'",
          "nocodb-tables": "curl -s -H \"xc-token: $NOCODB_API_TOKEN\" \"$NOCODB_URL/api/v1/db/meta/projects/$1/tables\" | jq '.list[] | {id: .id, title: .title}'"
        },
        "examples": [
          "nocodb-bases",
          "psql -d nocodb -c \"SELECT title FROM nc_projects ORDER BY created_at DESC LIMIT 10;\""
        ],
        "database": "nocodb"
      }
    },

    "baserow": {
      "name": "baserow",
      "displayName": "Baserow",
      "description": "No-code database and Airtable alternative",
