        "DATABASE_URL": "postgres://harness:{{harness.postgres.password}}@harness-postgres:5432/docmost",
        "APP_SECRET": "{{generate:hex:32}}",
        "APP_URL": "http://docmost.{{domain}}"
      },
      "ports": { "internal": 3000 },
      "volumes": { "data": "/app/data/storage" },
      "healthCheck": { "path": "/", "interval": 30 },
      "cli": {
        "tools": ["psql", "curl", "jq"],
        "envDoc": {
          "DOCMOST_TOKEN": "API token for Docmost",
          "DOCMOST_URL": "Base URL for Docmost"
        },
        "aliases": {
          "docmost-spaces": "curl -s -H \"Authorization: Bearer $DOCMOST_TOKEN\" \"$DOCMOST_URL/api/spaces\" | jq '.data[] | {id: .id, name: .name}'",
          "docmost-pages": "curl -s -H \"Authorization: Bearer $DOCMOST_TOKEN\" \"$DOCMOST_URL/api/pages?spaceId=$1\" | jq '.data[] | {id: .id, title: .title}'"
        },
        "examples": [
