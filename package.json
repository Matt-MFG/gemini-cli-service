{
  "name": "gemini-cli-service",
  "version": "0.1.0",
  "description": "Gemini CLI as a Service — cloud-hosted Gemini CLI accessible from chat platforms",
  "main": "src/daemon/index.js",
  "scripts": {
    "start": "node src/daemon/index.js",
    "dev": "node --watch src/daemon/index.js",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "test:e2e": "node --test tests/e2e/**/*.test.js",
    "lint": "eslint src/ tests/",
    "coverage": "c8 node --test tests/unit/**/*.test.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.7.0",
    "dockerode": "^4.0.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "googleapis": "^171.4.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "c8": "^10.1.0",
    "eslint": "^9.0.0"
  },
  "license": "MIT"
}
