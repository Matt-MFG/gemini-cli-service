{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Gemini CLI stream-json Event Schema",
  "description": "Schema for events emitted by `gemini --output-format stream-json`. Each line of stdout is one JSON object. This schema is the contract between CLI output and the daemon parser (V-02).",
  "oneOf": [
    { "$ref": "#/definitions/turnStart" },
    { "$ref": "#/definitions/modelTurn" },
    { "$ref": "#/definitions/toolCall" },
    { "$ref": "#/definitions/toolResult" },
    { "$ref": "#/definitions/modelResponse" },
    { "$ref": "#/definitions/error" },
    { "$ref": "#/definitions/result" }
  ],
  "definitions": {
    "turnStart": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "turn_start" },
        "turn_number": { "type": "integer", "minimum": 1 },
        "session_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "modelTurn": {
      "type": "object",
      "required": ["type", "content"],
      "properties": {
        "type": { "const": "model_turn" },
        "content": { "type": "string" },
        "role": { "type": "string", "enum": ["model"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "toolCall": {
      "type": "object",
      "required": ["type", "tool_name"],
      "properties": {
        "type": { "const": "tool_call" },
        "tool_name": { "type": "string" },
        "tool_call_id": { "type": "string" },
        "args": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "toolResult": {
      "type": "object",
      "required": ["type", "tool_call_id"],
      "properties": {
        "type": { "const": "tool_result" },
        "tool_call_id": { "type": "string" },
        "output": { "type": "string" },
        "error": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "modelResponse": {
      "type": "object",
      "required": ["type", "content"],
      "properties": {
        "type": { "const": "model_response" },
        "content": { "type": "string" },
        "finish_reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "error": {
      "type": "object",
      "required": ["type", "message"],
      "properties": {
        "type": { "const": "error" },
        "message": { "type": "string" },
        "code": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "result": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "result" },
        "session_id": { "type": "string" },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cached_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
